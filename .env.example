# Baton Studio production example
#
# Copy to .env for docker compose or export these values in your shell.

BATON_ENV=production
BATON_API_KEY=change-me-long-random-admin-token
# Optional scoped tokens. Roles: reader, operator, admin.
# BATON_API_KEYS=read-token:reader,ops-token:operator,admin-token:admin
BATON_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BATON_DATABASE_URL=sqlite+aiosqlite:////data/baton.sqlite

NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_WS_URL=ws://localhost:8787
# Only expose this for trusted internal deployments.
# NEXT_PUBLIC_BATON_API_KEY=change-me-long-random-admin-token
